# Copy to .env and adjust. All variables are optional; defaults shown.

# Server (loopback only — non-loopback hosts are rejected by design)
#JARVIS_HOST=127.0.0.1
#JARVIS_PORT=8765
# When set, all endpoints except /health require "Authorization: Bearer <token>"
#JARVIS_AUTH_TOKEN=

# Ollama / models
#JARVIS_OLLAMA_HOST=http://127.0.0.1:11434
# Use non-thinking instruct models; reasoning models (qwen3, deepseek-r1)
# add tens of seconds of hidden "thinking" per reply on 8GB hardware.
#JARVIS_LLM_MODEL=qwen2.5:3b-instruct-q4_K_M
#JARVIS_LLM_POWER_MODEL=qwen2.5:7b-instruct-q4_K_M
#JARVIS_POWER_MODE=false
#JARVIS_VISION_MODEL=qwen2.5vl:3b
#JARVIS_LLM_KEEP_ALIVE=30m
#JARVIS_REQUEST_TIMEOUT_SECONDS=120

# Chat
#JARVIS_MAX_HISTORY_MESSAGES=20
#JARVIS_LOG_LEVEL=INFO
